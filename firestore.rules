rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to validate data on create/update
    function isValidOwner() {
       return request.resource.data.userId == request.auth.uid;
    }

    // Rules for all collections
    // Vendors
    match /vendors/{vendorId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId) && isValidOwner();
    }

    // Payments
    match /payments/{paymentId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId) && isValidOwner();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId) && isValidOwner();
    }

    // Guests
    match /guests/{guestId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId) && isValidOwner();
    }

    // Gifts
    match /gifts/{giftId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId) && isValidOwner();
    }
  }
}