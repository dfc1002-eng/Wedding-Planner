rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Função para verificar se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Função para verificar se o usuário é dono do documento (pelo UID do Auth)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica se o documento existente pertence ao usuário (pelo campo userId nos dados)
    function isResourceOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Verifica se os NOVOS dados pertencem ao usuário (Para criar)
    function isValidOwner() {
       return request.resource.data.userId == request.auth.uid;
    }

    // --- REGRAS ---

    // 1. Coleção USERS (Permite Onboarding)
    match /users/{userId} {
      // Público pode ler (necessário para RSVP ver nomes)
      allow get: if true;
      // Dono pode fazer tudo (criar, listar, editar)
      allow list, create, update, delete: if isOwner(userId);
    }

    // 2. Coleção GUESTS (Permite RSVP Público)
    match /guests/{guestId} {
      // Público pode ler e atualizar (confirmar presença)
      allow read, update: if true;
      // Só dono cria ou apaga
      allow create: if isValidOwner();
      allow delete: if isResourceOwner();
    }

    // 3. Outras Coleções (Privadas)
    match /vendors/{vendorId} {
      allow read, delete, update: if isResourceOwner();
      allow create: if isValidOwner();
    }
    
    match /payments/{paymentId} {
      allow read, delete, update: if isResourceOwner();
      allow create: if isValidOwner();
    }
    
    match /tasks/{taskId} {
      allow read, delete, update: if isResourceOwner();
      allow create: if isValidOwner();
    }
    
    match /gifts/{giftId} {
      allow read, delete, update: if isResourceOwner();
      allow create: if isValidOwner();
    }
  }
}