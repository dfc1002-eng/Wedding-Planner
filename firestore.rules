rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções Auxiliares
    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o documento JÁ EXISTENTE pertence ao usuário
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Verifica se os NOVOS dados pertencem ao usuário 
    function isValidOwner() {
       return request.resource.data.userId == request.auth.uid;
    }

    // --- Regras por Coleção ---

    match /vendors/{vendorId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      // 🔒 SEGURO: Só o dono pode atualizar
      allow update: if isOwner(resource.data.userId);
    }

    match /payments/{paymentId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      // 🔒 SEGURO: Só o dono pode atualizar
      allow update: if isOwner(resource.data.userId);
    }

    match /tasks/{taskId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId);
    }

    match /guests/{guestId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId);
    }

    match /gifts/{giftId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isValidOwner();
      allow update: if isOwner(resource.data.userId);
    }
  }
}